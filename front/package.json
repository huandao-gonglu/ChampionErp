{
  "name": "champion-erp-front",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "desktop/main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vue-tsc -b && vite build",
    "build:desktop": "vue-tsc -b && vite build --mode desktop",
    "desktop:dev": "pnpm build:desktop && electron .",
    "desktop:pack": "pnpm build:desktop && electron-builder --dir",
    "desktop:dist": "pnpm build:desktop && electron-builder",
    "preview": "vite preview --host 127.0.0.1",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "lint:check": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@vueuse/core": "^11.3.0",
    "axios": "^1.16.1",
    "chart.js": "^4.5.1",
    "pinia": "^2.3.1",
    "vue": "^3.5.35",
    "vue-chartjs": "^5.3.3",
    "vue-i18n": "^9.14.5",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitest/coverage-v8": "^2.1.9",
    "@vue/test-utils": "^2.4.10",
    "autoprefixer": "^10.5.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^9.33.0",
    "globals": "^15.15.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^5.4.21",
    "vite-plugin-checker": "^0.8.0",
    "vitest": "^2.1.9",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^2.2.12"
  },
  "build": {
    "appId": "com.champion.erp.front",
    "productName": "Champion ERP",
    "directories": {
      "output": "release"
    },
    "files": [
      "desktop/**/*",
      "dist-desktop/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}
